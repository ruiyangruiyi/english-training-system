# 数据库 - 本地开发
DATABASE_URL="file:./dev.db"

# 数据库 - Turso 云数据库（生产环境）
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_auth_token

# 企业微信配置
WECOM_CORP_ID=your_corp_id
WECOM_AGENT_ID=your_agent_id
