generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("TURSO_DATABASE_URL")
  directUrl = env("TURSO_DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  username String   @unique
  password String
  name     String
  phone    String?
  wechat   String?
  subject  String?
  status   String   @default("active") // pending, active, disabled
  role     String   @default("teacher") // admin, teacher
  classes  Class[]  @relation("TeacherClasses")
}

model Class {
  id              Int       @id @default(autoincrement())
  name            String
  grade           String
  schedule        String
  wechatGroupId   String?   @map("wechat_group_id")
  wechatGroupName String?   @map("wechat_group_name")
  teacherId       Int?      @map("teacher_id")
  teacher         User?     @relation("TeacherClasses", fields: [teacherId], references: [id])
  students        Student[]
  attendances     Attendance[]
  homeworkClasses HomeworkClass[]
}

model Student {
  id          Int       @id @default(autoincrement())
  name        String
  grade       String
  parentPhone String
  classId     Int?
  class       Class?    @relation(fields: [classId], references: [id])
  attendances Attendance[]
  payments    Payment[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  classId   Int
  studentId Int
  date      DateTime
  status    String
  remark    String?
  class     Class    @relation(fields: [classId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])
}

model Payment {
  id            Int       @id @default(autoincrement())
  studentId     Int
  term          String
  status        String
  amount        Float?
  paymentMethod String?
  paidAt        DateTime?
  student       Student   @relation(fields: [studentId], references: [id])
}

model Homework {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  dueDate     DateTime
  createdAt   DateTime  @default(now())
  homeworkClasses HomeworkClass[]
  completions HomeworkCompletion[]
}

model HomeworkClass {
  id         Int      @id @default(autoincrement())
  homeworkId Int
  classId    Int
  homework   Homework @relation(fields: [homeworkId], references: [id])
  class      Class    @relation(fields: [classId], references: [id])

  @@unique([homeworkId, classId])
}

model HomeworkCompletion {
  id          Int       @id @default(autoincrement())
  homeworkId  Int       @map("homework_id")
  wechatUserId String   @map("wechat_user_id")
  wechatName  String?   @map("wechat_name")
  completedAt DateTime  @default(now()) @map("completed_at")
  homework    Homework  @relation(fields: [homeworkId], references: [id])

  @@unique([homeworkId, wechatUserId])
}

model ChatSession {
  id            Int       @id @default(autoincrement())
  userId        String    @unique @map("user_id")
  sessionType   String    @map("session_type")
  currentStep   String    @map("current_step")
  data          String    @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  expiresAt     DateTime  @map("expires_at")
}
